import java.util.concurrent.*;
public class Main {
    public static void main(String[] args)
    throws Exception {
        ExecutorService executor =
        Executors.newFixedThreadPool(3);
        Callable<String> task1 = () -> "Music Event";
        Callable<String> task2 = () -> "Sports Event";
        Callable<String> task3 = () -> "Food Festival";
        Future<String> result1 = executor.submit(task1);
        Future<String> result2 = executor.submit(task2);
        Future<String> result3 = executor.submit(task3);
        System.out.println( result1.get());
        System.out.println(result2.get());
        System.out.println(result3.get());
        executor.shutdown();
    }
}
