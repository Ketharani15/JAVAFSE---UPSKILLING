public class Main {
    public static void main(String[] args)
    throws Exception {
        long startTime =
        System.currentTimeMillis();
        for(int i = 1; i <= 100000; i++) {
            int id = i;
            Thread.startVirtualThread(() -> {
                System.out.println(
                    "Virtual Thread " + id
                );
            });
        }
        Thread.sleep(2000);
        long endTime =
        System.currentTimeMillis();
        System.out.println(
            "Time Taken: "
            + (endTime - startTime)
            + " ms"
        );
    }
}
