import java.lang.reflect.*;
public class Main {
    public static void main(String[] args)
    throws Exception {
        Class<?> cls =
        Class.forName("Student");
        System.out.println(
            "Methods:"
        );
        Method[] methods =
        cls.getDeclaredMethods();
        for(Method m : methods) {
            System.out.println(
                m.getName()
            );
            System.out.println(
                "Parameters: "
                + m.getParameterCount()
            );
        }
        Object obj =
        cls.getDeclaredConstructor()
        .newInstance();
        Method method =
        cls.getDeclaredMethod(
            "display"
        );
        method.invoke(obj);
    }
}
