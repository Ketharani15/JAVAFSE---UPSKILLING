import java.sql.*;
public class StudentDAO {
    Connection con;
    public StudentDAO() throws Exception {
        Class.forName("com.mysql.cj.jdbc.Driver");
        con = DriverManager.getConnection(
            "jdbc:mysql://localhost:3306/studentdb",
            "root",
            "password"
        );
    }
    public void insertStudent(
        int id,
        String name,
        int age
    ) throws Exception {
        String query =
        "INSERT INTO students VALUES(?,?,?)";
        PreparedStatement ps =
        con.prepareStatement(query);
        ps.setInt(1, id);
        ps.setString(2, name);
        ps.setInt(3, age);
        ps.executeUpdate();
        System.out.println(
            "Student Inserted"
        );
    }
    public void updateStudent(
        int id,
        String name
    ) throws Exception {
        String query =
        "UPDATE students SET name=? WHERE id=?";
        PreparedStatement ps =
        con.prepareStatement(query);
        ps.setString(1, name);
        ps.setInt(2, id);
        ps.executeUpdate();
        System.out.println(
            "Student Updated"
        );
    } 
} //StudentDAO



public class Main {
    public static void main(String[] args) {
        try {
            StudentDAO dao =
            new StudentDAO();
            dao.insertStudent(
                4,
                "David",
                23
            );
            dao.updateStudent(
                4,
                "John"
            );
        } catch(Exception e) {
            System.out.println(e);
        }
    }
}  // Main java



CREATE TABLE students(
    id INT PRIMARY KEY,
    name VARCHAR(50),
    age INT
); //Students Table

