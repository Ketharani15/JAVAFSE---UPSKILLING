<!DOCTYPE html>
<html>
<head>
    <title>Table Styling</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <h2>
        Event Details
    </h2>
    <table>
        <tr>
            <th>Event</th>
            <th>Date</th>
            <th>Location</th>
        </tr>
        <tr>
            <td>Music Show</td>
            <td>10 June</td>
            <td>Chennai</td>
        </tr>
        <tr>
            <td>Food Festival</td>
            <td>15 June</td>
            <td>Madurai</td>
        </tr>
        <tr>
            <td>Tech Expo</td>
            <td>20 June</td>
            <td>Coimbatore</td>
        </tr>
    </table>
</body>
</html>
